# Función para consultar estado y responsable de HUs en Azure DevOps
function consultar_estado_hus() {
    local AZ_ORG="https://dev.azure.com/SuratechDevOpsColombia"

    while true; do
        clear
        echo ""
        echo -e "  ${TITLE}"
        echo "  ╭────────────────────────────────────────────────────────╮"
        echo "  │               Gestión de Estado de HUs                 │"
        echo "  ╰────────────────────────────────────────────────────────╯"
        echo -e "  ${COLOR_RESET}"
        echo -e "  ${OPTION}1.${COLOR_RESET}  Consultar estado     ${MUTED}› Muestra estado y responsable de HUs${COLOR_RESET}"
        echo -e "  ${OPTION}2.${COLOR_RESET}  Actualizar estado    ${MUTED}› Cambia el estado de una o varias HUs${COLOR_RESET}"
        echo ""
        echo -e "  ${COLOR_SUCCESS}0.  Volver${COLOR_RESET}"
        echo ""
        echo -e "  ${DIM}────────────────────────────────────────────────────────${COLOR_RESET}"
        echo -e -n "  ${COLOR_PRIMARY}→${COLOR_RESET} "
        read opcion_hu

        case $opcion_hu in
            0) return 0 ;;

            1) # Consultar estado
                echo ""
                echo -e "  ${MUTED}Ingrese los IDs de las HUs a consultar${COLOR_RESET}"
                echo -e "  ${MUTED}Si son varias, sepárelas con espacios:${COLOR_RESET}"
                echo -e "  ${COLOR_ACCENT}  Ej: 35365 35360 35367${COLOR_RESET}"
                echo ""
                echo -e -n "  ${COLOR_PRIMARY}→${COLOR_RESET} "
                read hu_input

                if [ -z "$hu_input" ]; then
                    echo -e "\n  ${COLOR_WARNING}No se ingresaron IDs.${COLOR_RESET}"
                    sleep 1; continue
                fi

                echo ""
                echo -e "  ${MUTED}──────────────────────────────────────────────────────${COLOR_RESET}"

                for id in $hu_input; do
                    id="${id#HU-}"
                    echo ""
                    echo -e "  ${COLOR_ACCENT}HU-${id}${COLOR_RESET}"

                    resultado=$(az boards work-item show --id "$id" --org "$AZ_ORG" 2>&1)

                    if echo "$resultado" | grep -q "ERROR\|error"; then
                        echo -e "  ${COLOR_ERROR}✗ No se pudo obtener HU-${id}. Verifica el ID.${COLOR_RESET}"
                        continue
                    fi

                    echo "$resultado" | python3 -c "
import json, sys
data = json.load(sys.stdin)
f = data.get('fields', {})
assigned = f.get('System.AssignedTo', '')
if isinstance(assigned, dict):
    assigned = assigned.get('displayName', '-')
print(f'  Título:      {f.get(\"System.Title\", \"-\")}')
print(f'  Estado:      {f.get(\"System.State\", \"-\")}')
print(f'  Responsable: {assigned}')
"
                    echo -e "  ${MUTED}──────────────────────────────────────────────────────${COLOR_RESET}"
                done

                echo ""
                echo -e "  ${MUTED}Presiona ENTER para volver${COLOR_RESET}"
                read foo
            ;;

            2) # Actualizar estado
                echo ""
                echo -e "  ${MUTED}Ingrese los IDs de las HUs a actualizar${COLOR_RESET}"
                echo -e "  ${MUTED}Si son varias, sepárelas con espacios:${COLOR_RESET}"
