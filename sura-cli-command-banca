# Función para mostrar cuadro de confirmación dinámico
function mostrar_confirmacion() {
    local operacion="$1"   # VALIDATE, DEPLOY, RETRIEVE, DESTRUCTIVE
    local tipo="$2"        # CORE, VLOCITY
    local org_name="$3"    # DEVBANCA, SITBANCA, etc.
    local color_name="$4"  # WARNING, ERROR, SUCCESS
    local descripcion="$5" # Descripción corta

    # Obtener el código de color según el nombre
    local color_code=""
    case "$color_name" in
        WARNING) color_code="$WARNING" ;;
        ERROR) color_code="$ERROR" ;;
        SUCCESS) color_code="$SUCCESS" ;;
        *) color_code="$COLOR_PRIMARY" ;;
    esac

    # Solo chars ASCII/narrow — sin Unicode ambiguo para evitar desfase visual
    local texto="$(printf '%-9s' "$operacion")  ${tipo}  >  ${org_name}"

    # Caja de ancho fijo (el texto típico es ~47 chars, box_inner=58 da margen)
    local box_inner=58
    local text_len=${#texto}
    local right_pad=$(( box_inner - text_len - 2 ))
    [ $right_pad -lt 1 ] && right_pad=1
    local border=$(printf '─%.0s' $(seq 1 $box_inner))
    local rpad=$(printf '%*s' "$right_pad" '')

    echo ""
    echo -e "  ${color_code}╭${border}╮${COLOR_RESET}"
    echo -e "  ${color_code}│${COLOR_RESET}  ${texto}${rpad}${color_code}│${COLOR_RESET}"
    echo -e "  ${color_code}╰${border}╯${COLOR_RESET}"
    echo -e "  ${MUTED}${descripcion}${COLOR_RESET}"
    echo ""
}

