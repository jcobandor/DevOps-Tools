        echo -e "${COLOR_WARNING}  No olvide cambiar el estado a: ${COLOR_BOLD}Disponible para pruebas aliado${COLOR_RESET}"
    else
        echo -e "${COLOR_MUTED}  No se encontraron Work Items asociados al PR${COLOR_RESET}"
    fi

    return 0
}

