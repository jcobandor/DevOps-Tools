        echo -e "${COLOR_ERROR}  El PR #${pr_id} fue abandonado.${COLOR_RESET}"
        return 1
    fi

    # Obtener fecha y hora de Bogotá (UTC-5)
    local fecha_bogota=$(TZ='America/Bogota' date '+%Y-%m-%d %H:%M:%S')
    local comentario="✅ **PR completado via DevOps CLI Tool (Proceso Automatizado)**

📅 Fecha: ${fecha_bogota} (Bogotá, Colombia)
🔧 Acción: Deploy exitoso a SITBANCA + Tracking registrado
👤 Ejecutado por: juan.obando@nespon.com"

    # Agregar comentario al PR
    echo -e "\n${COLOR_INFO}Agregando comentario al PR #${pr_id}...${COLOR_RESET}"
    az repos pr update --id "$pr_id" --description "$(az repos pr show --id $pr_id --query description -o tsv 2>/dev/null)

---
${comentario}" --output none 2>/dev/null
    if [ $? -eq 0 ]; then
        echo -e "${COLOR_SUCCESS}  ✓ Comentario agregado al PR #${pr_id}${COLOR_RESET}"
    else
        echo -e "${COLOR_WARNING}  ⚠ No se pudo agregar comentario (continuando...)${COLOR_RESET}"
    fi

    # Aprobar el PR
    echo -e "${COLOR_INFO}Aprobando PR #${pr_id}...${COLOR_RESET}"
    az repos pr set-vote --id "$pr_id" --vote approve --output none 2>/dev/null
    if [ $? -eq 0 ]; then
        echo -e "${COLOR_SUCCESS}  ✓ PR #${pr_id} aprobado exitosamente${COLOR_RESET}"
    else
        echo -e "${COLOR_ERROR}  ✗ Error al aprobar el PR #${pr_id}${COLOR_RESET}"
        echo -e "${COLOR_MUTED}  Verifique que está autenticado: az login${COLOR_RESET}"
        return 1
    fi

    # Completar el PR
    echo -e "${COLOR_INFO}Completando PR #${pr_id}...${COLOR_RESET}"
    az repos pr update --id "$pr_id" --status completed --output none 2>/dev/null
    if [ $? -eq 0 ]; then
        echo -e "${COLOR_SUCCESS}  ✓ PR #${pr_id} completado exitosamente${COLOR_RESET}"
    else
        echo -e "${COLOR_ERROR}  ✗ Error al completar el PR #${pr_id}${COLOR_RESET}"
        echo -e "${COLOR_MUTED}  El PR puede requerir más aprobaciones o tener políticas pendientes${COLOR_RESET}"
        return 1
    fi

    echo -e "\n${COLOR_SUCCESS}╔═══════════════════════════════════════════════════════════╗"
    echo -e "║              PR Aprobado y Completado ✓                   ║"
    echo -e "╚═══════════════════════════════════════════════════════════╝${COLOR_RESET}"

    # Obtener y abrir Work Items asociados al PR
    echo -e "\n${COLOR_INFO}Buscando Work Items asociados al PR #${pr_id}...${COLOR_RESET}"
    local work_items=$(az repos pr work-item list --id "$pr_id" --query "[].id" -o tsv 2>/dev/null)

    if [ -n "$work_items" ]; then
        local count=0
        while IFS= read -r wi_id; do
            if [ -n "$wi_id" ]; then
                ((count++))
                local wi_url="https://dev.azure.com/SuratechDevOpsColombia/Suratech%20Colombia/_workitems/edit/${wi_id}"
                echo -e "${COLOR_SUCCESS}  ✓ Abriendo Work Item #${wi_id}...${COLOR_RESET}"
