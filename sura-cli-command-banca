    if [ -z "$pr_id" ]; then
        echo -e "${COLOR_WARNING}No hay PR ID disponible.${COLOR_RESET}"
        return 1
    fi

    echo -e "\n${COLOR_INFO}${COLOR_BOLD}╔═══════════════════════════════════════════════════════════╗"
    echo -e "║              Azure DevOps - Gestión de PR                 ║"
    echo -e "╚═══════════════════════════════════════════════════════════╝${COLOR_RESET}"

    echo -e "\n${COLOR_PRIMARY}→${COLOR_RESET} ${COLOR_TEXT}¿Desea aprobar y completar el PR #${pr_id} en Azure? (S/N):${COLOR_RESET} "
    read aprobar_pr

    if [[ ! "$aprobar_pr" =~ ^[Ss]$ ]]; then
        echo -e "${COLOR_MUTED}Operación de PR omitida.${COLOR_RESET}"
        return 0
    fi

    # Verificar que az CLI está instalado
    if ! command -v az &> /dev/null; then
