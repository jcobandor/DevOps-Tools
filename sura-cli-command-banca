# ============================================================================
# FUNCIÓN: Verificar componentes híbridos en los manifests de deploy
# Compara los manifests de deploy contra las listas de componentes híbridos
# y muestra una alerta si encuentra coincidencias
# ============================================================================
function verificar_hibridos() {
    local SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local PACKAGE_XML="$PROJECT_ROOT/${MANIFEST_DIR}/${XML_COMPONENTES}"
    local PACKAGE_YAML="$PROJECT_ROOT/${MANIFEST_DIR}/${YAML_COMPONENTES}"
    local HIBRIDOS_XML="$SCRIPT_DIR/package_hibridos.xml"
    local HIBRIDOS_YAML="$SCRIPT_DIR/package_hibridos.yaml"

    # Verificar que existan los archivos de híbridos
    if [ ! -f "$HIBRIDOS_XML" ] && [ ! -f "$HIBRIDOS_YAML" ]; then
        return 0
    fi

    local hibridos_core=()
    local hibridos_vlocity=()

    # --- CORE: Comparar XML (con tipo de metadato) ---
    if [ -f "$HIBRIDOS_XML" ] && [ -f "$PACKAGE_XML" ]; then
        # Extraer pares "TipoMetadato|NombreMiembro" del XML de híbridos
        # El <name> viene después de los <members>, así que se procesa por bloques <types>
        while IFS='|' read -r tipo member; do
            member=$(echo "$member" | xargs)
            if [ -n "$member" ] && grep -q "<members>$member</members>" "$PACKAGE_XML"; then
                hibridos_core+=("[${tipo}] ${member}")
            fi
        done < <(perl -0777 -ne '
            while (/<types>(.*?)<\/types>/gs) {
                my $block = $1;
                my ($name) = $block =~ /<name>(.*?)<\/name>/;
                while ($block =~ /<members>(.*?)<\/members>/g) {
                    print "$name|$1\n";
                }
            }
        ' "$HIBRIDOS_XML")
    fi

    # --- VLOCITY: Comparar YAML ---
    if [ -f "$HIBRIDOS_YAML" ] && [ -f "$PACKAGE_YAML" ]; then
        local deploy_list
        deploy_list=$(grep -oE '  - [^ ]+/.+' "$PACKAGE_YAML" | sed 's/^  - //' | sed 's/[[:space:]]*#.*$//' | sed 's/[[:space:]]*$//')
        local hibridos_list
        hibridos_list=$(grep -oE '  - [^ ]+/.+' "$HIBRIDOS_YAML" | sed 's/^  - //' | sed 's/[[:space:]]*#.*$//' | sed 's/[[:space:]]*$//')

        while IFS= read -r item; do
            if [ -n "$item" ] && grep -qx "$item" <<< "$deploy_list"; then
                hibridos_vlocity+=("$item")
            fi
        done <<< "$hibridos_list"
    fi

    local total=$(( ${#hibridos_core[@]} + ${#hibridos_vlocity[@]} ))

    if [ $total -gt 0 ]; then
        echo ""
        echo -e "  ${WARNING}╭──────────────────────────────────────────────────╮${COLOR_RESET}"
        echo -e "  ${WARNING}│    ALERTA: Componentes híbridos detectados       │${COLOR_RESET}"
        echo -e "  ${WARNING}╰──────────────────────────────────────────────────╯${COLOR_RESET}"
        echo ""

        if [ ${#hibridos_core[@]} -gt 0 ]; then
            echo -e "  ${COLOR_ACCENT}CORE (${#hibridos_core[@]}):${COLOR_RESET}"
            local prev_core_type=""
            local sorted_core
            sorted_core=$(printf '%s\n' "${hibridos_core[@]}" | sort)
            while IFS= read -r h; do
                local ctype="${h%%]*}"
                ctype="${ctype#\[}"
                if [ "$ctype" != "$prev_core_type" ]; then
                    [ -n "$prev_core_type" ] && echo ""
                    echo -e "    ${COLOR_INFO}${ctype}:${COLOR_RESET}"
                    prev_core_type="$ctype"
                fi
                local cname="${h#*] }"
                echo -e "      ${COLOR_WARNING}→${COLOR_RESET} $cname"
            done <<< "$sorted_core"
            echo ""
        fi

        if [ ${#hibridos_vlocity[@]} -gt 0 ]; then
            echo -e "  ${COLOR_ACCENT}VLOCITY (${#hibridos_vlocity[@]}):${COLOR_RESET}"
            local prev_type=""
            local sorted_vlocity
            sorted_vlocity=$(printf '%s\n' "${hibridos_vlocity[@]}" | sort)
            while IFS= read -r h; do
                local vtype="${h%%/*}"
                if [ "$vtype" != "$prev_type" ]; then
                    [ -n "$prev_type" ] && echo ""
                    echo -e "    ${COLOR_INFO}${vtype}:${COLOR_RESET}"
                    prev_type="$vtype"
                fi
                local vname="${h#*/}"
                echo -e "      ${COLOR_WARNING}→${COLOR_RESET} $vname"
            done <<< "$sorted_vlocity"
            echo ""
        fi

        echo -e "  ${COLOR_ERROR}Total híbridos encontrados: ${total}${COLOR_RESET}"
        echo -e "  ${MUTED}Verifique estos componentes antes de continuar con el deploy${COLOR_RESET}"
        echo ""
    else
        echo -e "\n  ${COLOR_SUCCESS}✓ No se detectaron componentes híbridos${COLOR_RESET}\n"
    fi
}

# ============================================================================
# FUNCIÓN: Verificar componentes híbridos por PR ID
# Obtiene los archivos modificados del PR y los compara contra las listas
# de componentes híbridos
# ============================================================================
function verificar_hibridos_por_pr() {
    local pr_id="$1"
    local SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local HIBRIDOS_XML="$SCRIPT_DIR/package_hibridos.xml"
    local HIBRIDOS_YAML="$SCRIPT_DIR/package_hibridos.yaml"

    if [ ! -f "$HIBRIDOS_XML" ] && [ ! -f "$HIBRIDOS_YAML" ]; then
        return 0
    fi

    # Obtener info del PR (ramas origen y destino)
    echo -e "  ${COLOR_MUTED}Verificando componentes híbridos del PR #${pr_id}...${COLOR_RESET}"
    local pr_json
    pr_json=$(az repos pr show --id "$pr_id" --output json 2>/dev/null)

    if [ -z "$pr_json" ]; then
        echo -e "  ${COLOR_WARNING}No se pudo obtener info del PR #${pr_id}${COLOR_RESET}"
        return 1
    fi

    local source_branch
    source_branch=$(echo "$pr_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['sourceRefName'].replace('refs/heads/',''))" 2>/dev/null)
    local target_branch
    target_branch=$(echo "$pr_json" | python3 -c "import sys,json; print(json.load(sys.stdin)['targetRefName'].replace('refs/heads/',''))" 2>/dev/null)

    # Obtener archivos modificados del PR (las ramas ya fueron actualizadas por el script Python)
    local changed_files
    changed_files=$(git diff --name-only "origin/${target_branch}...origin/${source_branch}" 2>/dev/null)

    if [ -z "$changed_files" ]; then
        echo -e "\n  ${COLOR_SUCCESS}✓ No se detectaron componentes híbridos en el PR${COLOR_RESET}\n"
        return 0
    fi

    local hibridos_core=()
    local hibridos_vlocity=()

    # --- CORE: Comparar archivos del PR contra híbridos XML ---
    if [ -f "$HIBRIDOS_XML" ]; then
        # Obtener pares tipo|miembro del XML de híbridos
        local hybrid_members
        hybrid_members=$(perl -0777 -ne '
            while (/<types>(.*?)<\/types>/gs) {
                my $block = $1;
                my ($name) = $block =~ /<name>(.*?)<\/name>/;
                while ($block =~ /<members>(.*?)<\/members>/g) {
                    print "$name|$1\n";
                }
            }
        ' "$HIBRIDOS_XML")

        # Para cada miembro híbrido, verificar si está en los archivos del PR
        while IFS='|' read -r tipo member; do
            member=$(echo "$member" | xargs)
            [ -z "$member" ] && continue

            local found=false

            if [[ "$member" == *.* ]]; then
                # Nombre con punto (ej: Object.Field, Object.RecordType)
                local obj_name="${member%%.*}"
                local field_name="${member#*.}"
                while IFS= read -r file; do
                    if [[ "$file" == *"$obj_name"* ]] && [[ "$file" == *"$field_name"* ]]; then
                        found=true
                        break
                    fi
                done <<< "$changed_files"
            else
                # Nombre simple - buscar en los archivos
                if echo "$changed_files" | grep -q "$member"; then
                    found=true
                fi
            fi

            if [ "$found" = true ]; then
                hibridos_core+=("[${tipo}] ${member}")
            fi
        done <<< "$hybrid_members"
    fi

    # --- VLOCITY: Comparar archivos del PR contra híbridos YAML ---
    if [ -f "$HIBRIDOS_YAML" ]; then
        local hibridos_yaml_list
        hibridos_yaml_list=$(grep -oE '  - [^ ]+/.+' "$HIBRIDOS_YAML" | sed 's/^  - //' | sed 's/[[:space:]]*#.*$//' | sed 's/[[:space:]]*$//')

        # Extraer componentes Vlocity únicos de los archivos del PR
        local checked_vlocity=""
        while IFS= read -r file; do
            [[ "$file" != vlocity/* ]] && continue
            # Extraer Tipo/Nombre usando cut (compatible con bash 3)
            local vtype=$(echo "$file" | cut -d'/' -f2)
            local vname=$(echo "$file" | cut -d'/' -f3)
            local vref="${vtype}/${vname}"

            # Evitar duplicados
            if ! echo "$checked_vlocity" | grep -qx "$vref"; then
                checked_vlocity="${checked_vlocity}${vref}
"
                if echo "$hibridos_yaml_list" | grep -qx "$vref"; then
                    hibridos_vlocity+=("$vref")
                fi
            fi
        done <<< "$changed_files"
    fi

    # Mostrar resultados
    local total=$(( ${#hibridos_core[@]} + ${#hibridos_vlocity[@]} ))

    if [ $total -gt 0 ]; then
        echo ""
        echo -e "  ${WARNING}╭──────────────────────────────────────────────────╮${COLOR_RESET}"
        echo -e "  ${WARNING}│    ALERTA: Componentes híbridos detectados       │${COLOR_RESET}"
        echo -e "  ${WARNING}╰──────────────────────────────────────────────────╯${COLOR_RESET}"
        echo ""

        if [ ${#hibridos_core[@]} -gt 0 ]; then
            echo -e "  ${COLOR_ACCENT}CORE (${#hibridos_core[@]}):${COLOR_RESET}"
            local prev_core_type=""
            local sorted_core
            sorted_core=$(printf '%s\n' "${hibridos_core[@]}" | sort)
            while IFS= read -r h; do
                local ctype="${h%%]*}"
                ctype="${ctype#\[}"
                if [ "$ctype" != "$prev_core_type" ]; then
                    [ -n "$prev_core_type" ] && echo ""
                    echo -e "    ${COLOR_INFO}${ctype}:${COLOR_RESET}"
                    prev_core_type="$ctype"
                fi
                local cname="${h#*] }"
                echo -e "      ${COLOR_WARNING}→${COLOR_RESET} $cname"
            done <<< "$sorted_core"
            echo ""
        fi

        if [ ${#hibridos_vlocity[@]} -gt 0 ]; then
            echo -e "  ${COLOR_ACCENT}VLOCITY (${#hibridos_vlocity[@]}):${COLOR_RESET}"
            local prev_type=""
            local sorted_vlocity
            sorted_vlocity=$(printf '%s\n' "${hibridos_vlocity[@]}" | sort)
            while IFS= read -r h; do
                local vtype="${h%%/*}"
                if [ "$vtype" != "$prev_type" ]; then
                    [ -n "$prev_type" ] && echo ""
                    echo -e "    ${COLOR_INFO}${vtype}:${COLOR_RESET}"
                    prev_type="$vtype"
                fi
                local vname="${h#*/}"
                echo -e "      ${COLOR_WARNING}→${COLOR_RESET} $vname"
            done <<< "$sorted_vlocity"
            echo ""
        fi

        echo -e "  ${COLOR_ERROR}Total híbridos encontrados: ${total}${COLOR_RESET}"
        echo -e "  ${MUTED}Verifique estos componentes antes de continuar con el deploy${COLOR_RESET}"
        echo ""
    else
        echo -e "\n  ${COLOR_SUCCESS}✓ No se detectaron componentes híbridos en el PR${COLOR_RESET}\n"
    fi
}

