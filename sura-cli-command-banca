                        sf deploy metadata --metadata-dir itemToDelete/ --target-org ${ORG_DESTINO} --wait 10 #Valida antes de borrar
                        cd "$SCRIPT_DIR"
                        echo -e "* ENTER PARA VOLVER AL MENÚ * \n"
                        read foo
                    ;;
                    *)
                        echo "OPCIÓN INVÁLIDA..."
                        sleep 1
                    ;;
                esac
            done
        ;;
        2) # Metadata VLOCITY
            while :
            do
                mostrar_menu_yaml
                read opcion_yaml

                case $opcion_yaml in
                    0)
                        break # Volver al menú principal
                    ;;
                    1) # Retrieve YAML
                        seleccionar_org_origen
                        if [ -z "$ORG_ORIGEN" ]; then
                            continue
                        fi
                        # Confirmación
                        org_name=$(get_org_name "$ORG_ORIGEN")
                        mostrar_confirmacion "RETRIEVE" "${MANIFEST_DIR}/${YAML_COMPONENTES}" "$org_name" "WARNING" "Descarga de metadata Vlocity"
                        echo -e "  ${COLOR_PRIMARY}→${COLOR_RESET} ${COLOR_TEXT}¿Desea continuar? (S/N):${COLOR_RESET} "
                        read confirmacion
                        if [[ ! "$confirmacion" =~ ^[Ss]$ ]]; then
                            echo "Retrieve cancelado. Volviendo al menú..."
                            sleep 1
                            continue
                        fi
                        echo -e "INICIA PROCESO RETRIEVE YAML...\n"
                        cd "$PROJECT_ROOT"
                        vlocity -sfdx.username ${ORG_ORIGEN} -job ${MANIFEST_DIR}/${YAML_COMPONENTES} packExport
                        cd "$SCRIPT_DIR"
                        echo -e "* ENTER PARA VOLVER AL MENÚ * \n"
                        read foo
                    ;;
                    2) # Deploy YAML
                        seleccionar_org_destino
                        if [ -z "$ORG_DESTINO" ]; then
                            continue
                        fi

                        # Confirmación
                        org_name=$(get_org_name "$ORG_DESTINO")
                        mostrar_confirmacion "DEPLOY" "${MANIFEST_DIR}/${YAML_COMPONENTES}" "$org_name" "ERROR" "Ejecutando deploy"
                        echo -e "  ${COLOR_PRIMARY}→${COLOR_RESET} ${COLOR_TEXT}¿Confirma el despliegue? (S/N):${COLOR_RESET} "
                        read confirmacion

                        if [[ ! "$confirmacion" =~ ^[Ss]$ ]]; then
                            echo "Despliegue cancelado. Volviendo al menú..."
                            sleep 1
                            continue
                        fi

                        echo -e "INICIA DESPLIEGUE DE METADATA VLOCITY...\n"
                        cd "$PROJECT_ROOT"
                        vlocity -sfdx.username ${ORG_DESTINO} -job ${MANIFEST_DIR}/${YAML_COMPONENTES} packDeploy
                        cd "$SCRIPT_DIR"

                        # Si es la org de tracking (SITBANCA/SITVIAJES), ofrecer guardar en tracking
                        if [[ "$ORG_DESTINO" = "$ORG_TRACKING_TRIGGER" ]]; then
                            guardar_tracking_componentes_yaml "${MANIFEST_DIR}/${YAML_COMPONENTES}" "VLOCITY"
                            # Si se guardó el tracking, ofrecer aprobar/completar PR en Azure
                            if [ -n "$ULTIMO_PR_ID" ]; then
                                aprobar_completar_pr_azure "$ULTIMO_PR_ID"
                                ULTIMO_PR_ID=""  # Limpiar variable
                            fi
                        fi

                        echo -e "* ENTER PARA VOLVER AL MENÚ * \n"
                        read foo
                    ;;
                    *)
                        echo "OPCIÓN INVÁLIDA..."
                        sleep 1
                    ;;
                esac
            done
        ;;
        3) # Export List
            while :
            do
                mostrar_menu_export
                read opcion_export

                case $opcion_export in
                    0)
                        break # Volver al menú principal
                    ;;
                    1) # Export componentes CORE
                        seleccionar_org_origen
                        if [ -z "$ORG_ORIGEN" ]; then
                            continue
                        fi
                        echo -e "INICIA PROCESO EXPORTAR LISTA COMPONENTES CORE\n"
                        echo -e "${COLOR_SUCCESS} En la carpeta SCRIPTS encontrara el archivo allMetadataCore.xml con el listado de todos los componentes...${COLOR_RESET}"
                        cd "$PROJECT_ROOT"
                        sfdx force:source:manifest:create --from-org ${ORG_ORIGEN} -n allMetadataCore -d scripts
                        cd "$SCRIPT_DIR"
                        echo -e "* ENTER PARA VOLVER AL MENÚ * \n"
                        read foo
                    ;;
                    2) # Export objetos CORE en CSV
                        seleccionar_org_origen
                        if [ -z "$ORG_ORIGEN" ]; then
                            continue
                        fi
                        echo -e "INICIA PROCESO EXPORTAR LISTA OBJETOS CORE EN .CSV\n"
                        echo -e "${COLOR_SUCCESS} En la raíz encontrará el archivo allobjects.txt con todos los objetos...${COLOR_RESET}"
                        cd "$PROJECT_ROOT"
                        sfdx force:schema:sobject:list -o ${ORG_ORIGEN} > allobjects.txt
                        cd "$SCRIPT_DIR"
                        echo -e "* ENTER PARA VOLVER AL MENÚ * \n"
                        read foo
                    ;;
                    3) # Export componentes VLOCITY
                        seleccionar_org_origen
                        if [ -z "$ORG_ORIGEN" ]; then
                            continue
                        fi
                        echo -e "INICIA PROCESO EXPORTAR LISTA COMPONENTES VLOCITY\n"
                        echo -e "${COLOR_SUCCESS} En la raíz encontrará el archivo output.txt con todos los componentes...${COLOR_RESET}"
                        cd "$PROJECT_ROOT"
                        vlocity -sfdx.username ${ORG_ORIGEN} packGetAllAvailableExports --nojob > output.txt
                        cd "$SCRIPT_DIR"
                        echo -e "* ENTER PARA VOLVER AL MENÚ * \n"
                        read foo
                    ;;
                    *)
                        echo "OPCIÓN INVÁLIDA..."
                        sleep 1
                    ;;
                esac
            done
        ;;
        4) # Autenticar
            while :
            do
                mostrar_menu_autenticar
                read opcion_autenticar

                case $opcion_autenticar in
                    0)
                        break # Volver al menú principal
                    ;;
                    1) # Genera JSON de autenticación
                        seleccionar_org_destino
                        if [ -z "$ORG_DESTINO" ]; then
                            continue
                        fi
                        echo "Generando archivo de autenticación para ${ORG_DESTINO}..."
                        sf org display --target-org $ORG_DESTINO --verbose --json > authE$ORG_DESTINO.json
                        echo -e "${COLOR_SUCCESS}Archivo de autenticación generado en la carpeta SCRIPTS: authE$ORG_DESTINO.json${COLOR_RESET}"
                        echo -e "${COLOR_SUCCESS}Recuerde utilizar este comando para poder acceder al ambiente: sf force auth sfdxurl store --sfdx-url-file [authFile.json]${COLOR_RESET}"
                        echo -e "* ENTER PARA VOLVER AL MENÚ * \n"
                        read foo
                    ;;
                    2) # Abrir ORG
                        seleccionar_org_destino
                        if [ -z "$ORG_DESTINO" ]; then
                            continue
                        fi
                        echo -e "ABRIENDO ORG...\n"
                        PROJECT_ROOT="$(git -C "$(pwd)" rev-parse --show-toplevel 2>/dev/null || pwd)"
                        (cd "$PROJECT_ROOT" && sfdx force:org:open --target-org ${ORG_DESTINO})
                        echo -e "* ENTER PARA VOLVER AL MENÚ * \n"
                        read foo
                    ;;
                    *)
                        echo "OPCIÓN INVÁLIDA..."
                        sleep 1
                    ;;
                esac
            done
        ;;
        5) # Release
            while :
            do
                mostrar_menu_git
                read opcion_git

                case $opcion_git in
                    0)
                        break # Volver al menú principal
                    ;;
                    1) # Verificar Conflictos
                        # Ejecutar el script externo de verificación de conflictos
                        # Esto evita el problema de cambio de versión del script al cambiar de rama
                        SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
                        MANIFEST_DIR="${MANIFEST_DIR}" "${SCRIPT_DIR}/verificar-conflictos-git.sh"

                        echo ""
                        echo "* ENTER PARA VOLVER AL MENÚ * "
                        read foo
                    ;;
                    2) # Historial de Commits
                        historial_commits
                    ;;
                    3) # Replicar PR en Rama
                        crear_commit_hacia_uat

                        echo ""
                        echo "* ENTER PARA VOLVER AL MENÚ * "
                        read foo
                    ;;
                    4) # Monitor de PRs (Jarvis)
                        gestionar_monitor_prs
                    ;;
                    5) # Consultar Estado de HUs
                        consultar_estado_hus
                    ;;
                    *)
                        echo "OPCIÓN INVÁLIDA..."
                        sleep 1
                    ;;
                esac
            done
        ;;
        [Ee])
            cd "$(dirname "${BASH_SOURCE[0]}")"
            echo "SALIENDO DEL SCRIPT..."
            sleep 1
            clear
            break 2
        ;;
        *)
            echo "OPCIÓN INVÁLIDA..."
            sleep 1
        ;;
    esac
    done
done


