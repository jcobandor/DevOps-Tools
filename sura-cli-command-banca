# ============================================================================
# FUNCIÓN: Reporte de PRs Aprobados por Periodo
# ============================================================================
function verificar_cambios_por_fecha() {
    local SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local PROJECT_ROOT="$(git -C "$(pwd)" rev-parse --show-toplevel 2>/dev/null || pwd)"
    local PYTHON_SCRIPT="${SCRIPT_DIR}/pr_commit_report.py"

    if ! command -v python3 &> /dev/null; then
        echo -e "${COLOR_ERROR}Error: Python3 no está instalado${COLOR_RESET}"
        return 1
    fi

    if [ ! -f "$PYTHON_SCRIPT" ]; then
        echo -e "${COLOR_ERROR}Error: No se encontró el script ${PYTHON_SCRIPT}${COLOR_RESET}"
        return 1
    fi

    echo ""

        echo -e "  ${TITLE}"
        echo "  ╭───────────────────────────────────────────────────╮"
        echo "  │       Reporte de PRs Aprobados por Periodo        │"
        echo "  ╰───────────────────────────────────────────────────╯"
        echo -e "  ${COLOR_RESET}"
        echo -e "  ${MUTED}Consulta los PRs aprobados y sus componentes en un periodo de tiempo definido${COLOR_RESET}"
    echo ""
    local ayer=$(date -v-1d +'%Y-%m-%d' 2>/dev/null || date -d 'yesterday' +'%Y-%m-%d' 2>/dev/null)
    echo -e -n "  ${COLOR_PRIMARY}→${COLOR_RESET} ¿Ver reporte de PRs aprobados ayer ${MUTED}(${ayer})${COLOR_RESET}? ${COLOR_TEXT}[S/N]:${COLOR_RESET} "
    read respuesta_ayer

    local fecha_ingresada
    local fecha_final=""
    if [[ "$respuesta_ayer" =~ ^[Ss]$ ]]; then
        fecha_ingresada="$ayer"
    else
        echo ""
        echo -e "  ${MUTED}Nota: Las fechas corresponden a la fecha de aprobación del PR${COLOR_RESET}"
        echo -e "  ${COLOR_TEXT}¿Qué tipo de consulta desea?${COLOR_RESET}"
        echo -e "    ${OPTION}1.${COLOR_RESET} Día específico"
        echo -e "    ${OPTION}2.${COLOR_RESET} Rango de fechas"
        echo -e -n "  ${COLOR_PRIMARY}→${COLOR_RESET} Seleccione ${COLOR_TEXT}[1/2]:${COLOR_RESET} "
        read tipo_consulta

        if [[ "$tipo_consulta" == "2" ]]; then
            echo -e -n "  ${COLOR_PRIMARY}→${COLOR_RESET} Fecha inicial ${MUTED}(YYYY-MM-DD)${COLOR_RESET}: "
            read fecha_ingresada
            echo -e -n "  ${COLOR_PRIMARY}→${COLOR_RESET} Fecha final   ${MUTED}(YYYY-MM-DD)${COLOR_RESET}: "
            read fecha_final

            if ! echo "$fecha_ingresada" | grep -qE '^[0-9]{4}-[0-9]{2}-[0-9]{2}$'; then
                echo -e "${COLOR_ERROR}Formato inválido en fecha inicial. Use YYYY-MM-DD${COLOR_RESET}"
                sleep 2
                return 1
            fi
            if ! echo "$fecha_final" | grep -qE '^[0-9]{4}-[0-9]{2}-[0-9]{2}$'; then
                echo -e "${COLOR_ERROR}Formato inválido en fecha final. Use YYYY-MM-DD${COLOR_RESET}"
                sleep 2
                return 1
            fi
            if [[ "$fecha_final" < "$fecha_ingresada" ]]; then
                echo -e "${COLOR_ERROR}La fecha final no puede ser anterior a la inicial${COLOR_RESET}"
                sleep 2
                return 1
            fi
        else
            echo -e -n "  ${COLOR_PRIMARY}→${COLOR_RESET} Ingrese la fecha ${MUTED}(YYYY-MM-DD)${COLOR_RESET}: "
            read fecha_ingresada

            if ! echo "$fecha_ingresada" | grep -qE '^[0-9]{4}-[0-9]{2}-[0-9]{2}$'; then
                echo -e "${COLOR_ERROR}Formato inválido. Use YYYY-MM-DD${COLOR_RESET}"
                sleep 2
                return 1
            fi
        fi
    fi

    local date_label="$fecha_ingresada"
    if [[ -n "$fecha_final" ]]; then
        date_label="${fecha_ingresada} al ${fecha_final}"
    fi

    local timestamp=$(date +'%Y%m%d_%H%M%S')
    local output_file="${SCRIPT_DIR}/commit_report_daily_${fecha_ingresada}_${timestamp}.html"

    echo -e "\n${COLOR_INFO}Actualizando repositorio...${COLOR_RESET}"
    cd "$PROJECT_ROOT"
    git fetch origin --quiet && echo -e "${COLOR_SUCCESS}✓ Repositorio actualizado${COLOR_RESET}" || echo -e "${COLOR_WARNING}⚠ No se pudo actualizar el repo (continuando de todas formas)${COLOR_RESET}"

    echo -e "\n${COLOR_INFO}Buscando PRs aprobados: ${date_label} (todas las ramas)...${COLOR_RESET}"
    if [[ -n "$fecha_final" ]]; then
        python3 "$PYTHON_SCRIPT" --daily-report --date "$fecha_ingresada" --end-date "$fecha_final" --output "$output_file"
    else
        python3 "$PYTHON_SCRIPT" --daily-report --date "$fecha_ingresada" --output "$output_file"
    fi
    local exit_code=$?
    cd "$SCRIPT_DIR"

    if [ $exit_code -eq 0 ] && [ -f "$output_file" ]; then
        echo -e "\n${COLOR_SUCCESS}Archivo generado: ${output_file}${COLOR_RESET}"
        echo -e "${COLOR_INFO}Abriendo en navegador...${COLOR_RESET}"
        open "$output_file" 2>/dev/null || xdg-open "$output_file" 2>/dev/null || echo -e "${COLOR_MUTED}Abra el archivo manualmente${COLOR_RESET}"
    fi

    echo ""
    echo "* ENTER PARA CONTINUAR *"
    read foo
}

# ============================================================================
# FUNCIÓN: Migrar componentes de un PR a otra rama
# ============================================================================
function crear_commit_hacia_uat() {
    echo ""
    echo -e "  ${TITLE}"
    echo "  ╭─────────────────────────────────────────────────────╮"
    echo "  │      Migrar componentes de un PR a otra rama        │"
    echo "  ╰─────────────────────────────────────────────────────╯"
    echo -e "  ${COLOR_RESET}"
    echo -e "  ${MUTED}Trae los archivos de un PR completado y los aplica en la rama destino${COLOR_RESET}"
    echo ""

    # Pedir ID del Pull Request
    echo -e -n "  ${COLOR_TEXT}Ingrese el ID del Pull Request: ${COLOR_RESET}"
    read pr_id_input

    if [ -z "$pr_id_input" ]; then
        echo -e "  ${COLOR_WARNING}No se ingresó PR ID${COLOR_RESET}"
        return 1
    fi

    # Obtener info del PR desde Azure DevOps
    echo ""
    echo -e "  ${COLOR_INFO}Obteniendo información del PR #${pr_id_input}...${COLOR_RESET}"

    local pr_info
    pr_info=$(az repos pr show --id "$pr_id_input" --query "{title: title, status: status, mergeCommitId: lastMergeCommit.commitId, sourceBranch: sourceRefName, targetBranch: targetRefName}" -o json 2>/dev/null)

    if [ $? -ne 0 ] || [ -z "$pr_info" ]; then
        echo -e "  ${COLOR_ERROR}Error al obtener info del PR. Verifica el ID y tu autenticación en Azure.${COLOR_RESET}"
        return 1
    fi

    local pr_title
    pr_title=$(echo "$pr_info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('title',''))" 2>/dev/null)
    local pr_status
    pr_status=$(echo "$pr_info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status',''))" 2>/dev/null)
    local merge_commit
    merge_commit=$(echo "$pr_info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('mergeCommitId','') or '')" 2>/dev/null)
    local source_branch
    source_branch=$(echo "$pr_info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('sourceBranch','').replace('refs/heads/',''))" 2>/dev/null)
    local target_branch
    target_branch=$(echo "$pr_info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('targetBranch','').replace('refs/heads/',''))" 2>/dev/null)

    # Validar que el PR esté completado (aprobado/merged)
    if [ "$pr_status" != "completed" ]; then
        echo ""
        echo -e "  ${COLOR_ERROR}El PR #${pr_id_input} no está completado.${COLOR_RESET}"
        echo -e "  ${COLOR_ERROR}Estado actual: ${COLOR_ACCENT}${pr_status}${COLOR_RESET}"
        echo -e "  ${COLOR_WARNING}Solo se permiten PRs completados (aprobados y merged).${COLOR_RESET}"
        return 1
    fi

    # Mostrar info del PR
    echo ""
    echo -e "  ${COLOR_MUTED}─────────────────────────────────────────${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Título:   ${COLOR_ACCENT}${pr_title}${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Estado:   ${COLOR_SUCCESS}${pr_status}${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Origen:   ${COLOR_ACCENT}${source_branch}${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Destino:  ${COLOR_ACCENT}${target_branch}${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Commit:   ${COLOR_ACCENT}${merge_commit:0:12}${COLOR_RESET}"
    echo -e "  ${COLOR_MUTED}─────────────────────────────────────────${COLOR_RESET}"
    echo ""
    echo -e "  ${COLOR_INFO}Rama origen (donde se hizo merge): ${COLOR_ACCENT}${target_branch}${COLOR_RESET}"

    # Guardar rama actual para volver después
    local rama_original
    rama_original=$(git branch --show-current)

    # Pedir rama destino (detecta rama actual como sugerencia)
    echo ""
    echo -e -n "  ${COLOR_TEXT}¿La rama destino es ${COLOR_ACCENT}${rama_original}${COLOR_TEXT}? (S/N): ${COLOR_RESET}"
    read usar_rama_actual

    local rama_destino
    if [[ "$usar_rama_actual" =~ ^[Ss]$ ]]; then
        rama_destino="$rama_original"
    else
        echo -e -n "  ${COLOR_TEXT}Ingrese la rama destino (donde aplicar los cambios): ${COLOR_RESET}"
        read rama_destino
        if [ -z "$rama_destino" ]; then
            echo -e "  ${COLOR_WARNING}No se ingresó rama destino${COLOR_RESET}"
            return 1
        fi
    fi

    local PROJECT_ROOT
    PROJECT_ROOT="$(git -C "$(pwd)" rev-parse --show-toplevel 2>/dev/null || pwd)"
    local SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

    # Actualizar rama origen del PR (OBLIGATORIO para tener los cambios del merge)
    echo ""
    echo -e "  ${COLOR_INFO}Actualizando rama ${COLOR_ACCENT}${target_branch}${COLOR_INFO}...${COLOR_RESET}"
    local fetch_err
    fetch_err=$(git fetch origin "$target_branch" 2>&1)
    if [ $? -ne 0 ]; then
        echo -e "  ${COLOR_ERROR}Error al actualizar origin/${target_branch}:${COLOR_RESET}"
        echo -e "  ${COLOR_ERROR}${fetch_err}${COLOR_RESET}"
        echo -e "  ${COLOR_WARNING}Sin el fetch, los archivos del PR no estarán disponibles.${COLOR_RESET}"
        echo -e -n "  ${COLOR_TEXT}¿Continuar de todos modos? (S/N): ${COLOR_RESET}"
        read continuar_sin_fetch
        if [[ ! "$continuar_sin_fetch" =~ ^[Ss]$ ]]; then
            return 1
        fi
    else
        echo -e "  ${COLOR_SUCCESS}✓ origin/${target_branch} actualizada${COLOR_RESET}"
    fi

    # Obtener archivos cambiados en el PR (antes de cambiar de rama)
    echo ""
    echo -e "  ${COLOR_INFO}Obteniendo archivos del PR...${COLOR_RESET}"

    local archivos_pr
    archivos_pr=$(git diff-tree --no-commit-id --name-only -r -m "$merge_commit" 2>/dev/null | sort -u)

    if [ -z "$archivos_pr" ]; then
        echo -e "  ${COLOR_WARNING}No se encontraron archivos en el PR${COLOR_RESET}"
        return 1
    fi

    # Filtrar: solo archivos CORE (force-app/) y VLOCITY (vlocity/)
    local filtered_files=""
    local skipped_files=""
    local num_filtered=0
    local num_skipped=0

    while IFS= read -r archivo; do
        [ -z "$archivo" ] && continue
        if [[ "$archivo" == force-app/* ]] || [[ "$archivo" == vlocity/* ]]; then
            [ -n "$filtered_files" ] && filtered_files="${filtered_files}"$'\n'
            filtered_files="${filtered_files}${archivo}"
            num_filtered=$((num_filtered + 1))
        else
            [ -n "$skipped_files" ] && skipped_files="${skipped_files}"$'\n'
            skipped_files="${skipped_files}${archivo}"
            num_skipped=$((num_skipped + 1))
        fi
    done <<< "$archivos_pr"

    if [ -z "$filtered_files" ]; then
        echo -e "  ${COLOR_WARNING}Ningún archivo CORE o Vlocity en el PR${COLOR_RESET}"
        return 1
    fi

    echo ""
    echo -e "  ${COLOR_SUCCESS}Componentes (CORE/Vlocity): ${COLOR_ACCENT}${num_filtered}${COLOR_RESET}"
    if [ "$num_skipped" -gt 0 ]; then
        echo -e "  ${COLOR_MUTED}Archivos ignorados (no CORE/Vlocity): ${num_skipped}${COLOR_RESET}"
        echo "$skipped_files" | while IFS= read -r sf; do
            [ -n "$sf" ] && echo -e "    ${COLOR_MUTED}• ${sf}${COLOR_RESET}"
        done
    fi

    # Mostrar archivos a traer
    echo ""
    echo -e "  ${COLOR_INFO}Archivos a traer:${COLOR_RESET}"
    echo "$filtered_files" | while IFS= read -r archivo; do
        [ -n "$archivo" ] && echo -e "    ${COLOR_ACCENT}• ${archivo}${COLOR_RESET}"
    done

    # Confirmar
    echo ""
    echo -e "  ${COLOR_MUTED}─────────────────────────────────────────${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Rama actual:  ${COLOR_ACCENT}${rama_original}${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Rama destino: ${COLOR_ACCENT}${rama_destino}${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Archivos:     ${COLOR_ACCENT}${num_filtered}${COLOR_RESET}"
    echo -e "  ${COLOR_MUTED}─────────────────────────────────────────${COLOR_RESET}"
    echo ""
    echo -e -n "  ${COLOR_TEXT}¿Ejecutar? Se cambiará a ${COLOR_ACCENT}${rama_destino}${COLOR_TEXT}, se hará commit y se volverá a ${COLOR_ACCENT}${rama_original}${COLOR_TEXT} (S/N): ${COLOR_RESET}"
    read confirmar_checkout

    if [[ ! "$confirmar_checkout" =~ ^[Ss]$ ]]; then
        echo -e "  ${COLOR_MUTED}Operación cancelada${COLOR_RESET}"
        return 0
    fi

    # ── Worktree temporal o directorio actual ──
    local work_dir
    local use_worktree=false
    local tmp_worktree=""

    echo ""
    if [ "$rama_destino" = "$rama_original" ]; then
        # La rama destino ya está activa → trabajar directamente aquí
        echo -e "  ${COLOR_INFO}La rama destino es la rama actual → trabajando en directorio actual${COLOR_RESET}"
        work_dir="$PROJECT_ROOT"
    else
        # Crear worktree temporal para no cambiar de rama
        tmp_worktree=$(mktemp -d)
        echo -e "  ${COLOR_INFO}Preparando worktree temporal para ${COLOR_ACCENT}${rama_destino}${COLOR_INFO}...${COLOR_RESET}"

        local wt_err
        wt_err=$(git -C "$PROJECT_ROOT" worktree add "$tmp_worktree" "$rama_destino" 2>&1)
        if [ $? -ne 0 ]; then
            echo -e "  ${COLOR_ERROR}Error creando worktree: ${wt_err}${COLOR_RESET}"
            rm -rf "$tmp_worktree"
            return 1
        fi
        echo -e "  ${COLOR_SUCCESS}✓ Worktree creado (rama actual sin cambios)${COLOR_RESET}"
        work_dir="$tmp_worktree"
        use_worktree=true
    fi

    # ── Checkout de archivos desde merge commit ──
    echo -e "  ${COLOR_INFO}Trayendo archivos desde merge commit ${COLOR_ACCENT}${merge_commit:0:12}${COLOR_INFO}...${COLOR_RESET}"

    local checkout_ok=0
    local checkout_fail=0

    while IFS= read -r archivo; do
        [ -z "$archivo" ] && continue
        local checkout_err
        checkout_err=$(git -C "$work_dir" checkout "$merge_commit" -- "$archivo" 2>&1)
        if [ $? -eq 0 ]; then
            checkout_ok=$((checkout_ok + 1))
            echo -e "    ${COLOR_SUCCESS}✓ ${archivo}${COLOR_RESET}"
        else
            checkout_fail=$((checkout_fail + 1))
            echo -e "    ${COLOR_WARNING}✗ ${archivo}${COLOR_RESET}"
            echo -e "      ${COLOR_ERROR}${checkout_err}${COLOR_RESET}"
        fi
    done <<< "$filtered_files"

    echo ""
    echo -e "  ${COLOR_SUCCESS}✓ ${checkout_ok} archivos traídos${COLOR_RESET}"
    if [ "$checkout_fail" -gt 0 ]; then
        echo -e "  ${COLOR_WARNING}  ${checkout_fail} archivos no encontrados${COLOR_RESET}"
    fi

    # ── Commit ──
    local commit_msg="Migrate: PR #${pr_id_input} - ${pr_title}"
    echo ""
    echo -e "  ${COLOR_INFO}Creando commit en ${COLOR_ACCENT}${rama_destino}${COLOR_INFO}...${COLOR_RESET}"
    echo -e "  ${COLOR_MUTED}${commit_msg}${COLOR_RESET}"

    while IFS= read -r archivo; do
        [ -z "$archivo" ] && continue
        git -C "$work_dir" add "$archivo" 2>/dev/null
    done <<< "$filtered_files"
    local commit_created=false
    if git -C "$work_dir" commit -m "$commit_msg" 2>/dev/null; then
        echo -e "  ${COLOR_SUCCESS}✓ Commit creado en ${rama_destino}${COLOR_RESET}"
        commit_created=true
    else
        echo -e "  ${COLOR_WARNING}No hay cambios para commitear (archivos ya existían)${COLOR_RESET}"
    fi

    # ── Push a origin ──
    if [ "$commit_created" = true ]; then
        echo ""
        echo -e "  ${COLOR_INFO}Haciendo push a origin/${rama_destino}...${COLOR_RESET}"
        local push_err
        push_err=$(git -C "$work_dir" push origin "$rama_destino" 2>&1)
        if [ $? -eq 0 ]; then
            echo -e "  ${COLOR_SUCCESS}✓ Push exitoso a origin/${rama_destino}${COLOR_RESET}"
        else
            echo -e "  ${COLOR_ERROR}Error en push: ${push_err}${COLOR_RESET}"
            echo -e "  ${COLOR_WARNING}Puedes hacer push manual: git push origin ${rama_destino}${COLOR_RESET}"
        fi
    fi

    # ── Limpiar worktree (solo si se creó uno) ──
    if [ "$use_worktree" = true ]; then
        echo ""
        echo -e "  ${COLOR_INFO}Limpiando worktree temporal...${COLOR_RESET}"
        git -C "$PROJECT_ROOT" worktree remove "$tmp_worktree" --force 2>/dev/null
        rm -rf "$tmp_worktree" 2>/dev/null
        git -C "$PROJECT_ROOT" worktree prune 2>/dev/null
        echo -e "  ${COLOR_SUCCESS}✓ Worktree eliminado${COLOR_RESET}"
    fi

    echo ""
    echo -e "  ${COLOR_SUCCESS}${BOLD}╭───────────────────────────────────────╮${COLOR_RESET}"
    echo -e "  ${COLOR_SUCCESS}${BOLD}│         Operación completada          │${COLOR_RESET}"
    echo -e "  ${COLOR_SUCCESS}${BOLD}╰───────────────────────────────────────╯${COLOR_RESET}"
    echo ""
    echo -e "  ${COLOR_TEXT}PR:       ${COLOR_ACCENT}#${pr_id_input} - ${pr_title}${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Commit:   ${COLOR_ACCENT}en rama ${rama_destino}${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Archivos: ${COLOR_ACCENT}${checkout_ok} componentes${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Rama:     ${COLOR_ACCENT}${rama_original} (sin cambios)${COLOR_RESET}"
}

function _crear_commit_hacia_uat_PENDIENTE() {
    # TODO: Implementar lógica cuando el usuario defina el flujo
    local PROJECT_ROOT
    PROJECT_ROOT="$(git rev-parse --show-toplevel)"

    echo ""
    echo -e "  ${TITLE}"
    echo "  ╭───────────────────────────────────────╮"
    echo "  │      Migrar componentes de un PR a otra rama       │"
    echo "  ╰───────────────────────────────────────╯"
    echo -e "  ${COLOR_RESET}"

    # ── Fase 1: Actualizar UAT sin cambiar de rama ──
    echo -e "  ${COLOR_INFO}Actualizando referencia de UAT...${COLOR_RESET}"
    echo -e "  ${COLOR_MUTED}Ejecutando: git fetch origin uat${COLOR_RESET}"
    if ! git fetch origin uat 2>/dev/null; then
        echo -e "  ${COLOR_ERROR}Error al hacer fetch de UAT${COLOR_RESET}"
        return 1
    fi
    echo -e "  ${COLOR_SUCCESS}✓ Referencia origin/uat actualizada${COLOR_RESET}"
    echo ""

    # ── Fase 1b: Seleccionar o crear rama acumulativa ──
    echo -e "  ${COLOR_INFO}¿Rama acumulativa hacia UAT?${COLOR_RESET}"
    echo ""
    echo -e "  ${OPTION}1.${COLOR_RESET}  Crear nueva rama (basada en origin/uat)"
    echo -e "  ${OPTION}2.${COLOR_RESET}  Usar rama existente"
    echo ""
    echo -e "  ${MUTED}0.  Cancelar${COLOR_RESET}"
    echo ""
    echo -e "  ${DIM}───────────────────────────────────${COLOR_RESET}"
    echo -e -n "  ${COLOR_PRIMARY}→${COLOR_RESET} "
    read opcion_rama

    case $opcion_rama in
        0)
            echo -e "  ${COLOR_MUTED}Operación cancelada${COLOR_RESET}"
            return 0
        ;;
        1)
            # Generar nombre sugerido con fecha y consecutivo
            local fecha_hoy
            fecha_hoy=$(date +%d%m%y)
            local consecutivo=1
            while git show-ref --verify --quiet "refs/heads/clone-banca-uat-${fecha_hoy}-$(printf '%02d' $consecutivo)" 2>/dev/null || \
                  git ls-remote --heads origin "clone-banca-uat-${fecha_hoy}-$(printf '%02d' $consecutivo)" 2>/dev/null | grep -q .; do
                consecutivo=$((consecutivo + 1))
            done
            local nombre_sugerido="clone-banca-uat-${fecha_hoy}-$(printf '%02d' $consecutivo)"

            echo ""
            echo -e "  ${COLOR_INFO}Nombre sugerido: ${COLOR_ACCENT}${nombre_sugerido}${COLOR_RESET}"
            echo -e -n "  ${COLOR_TEXT}Presiona ENTER para aceptar o escribe otro nombre: ${COLOR_RESET}"
            read nombre_custom

            local nombre_rama="${nombre_custom:-$nombre_sugerido}"

            echo ""
            echo -e "  ${COLOR_INFO}Creando rama ${COLOR_ACCENT}${nombre_rama}${COLOR_INFO} basada en origin/uat...${COLOR_RESET}"

            local git_err
            git_err=$(git checkout -b "$nombre_rama" origin/uat 2>&1)
            if [ $? -eq 0 ]; then
                echo -e "  ${COLOR_SUCCESS}✓ Rama creada y activa: ${nombre_rama}${COLOR_RESET}"
            else
                if echo "$git_err" | grep -qi "overwritten\|conflict\|uncommitted\|local changes"; then
                    echo -e "  ${COLOR_WARNING}Hay cambios locales que impiden el checkout.${COLOR_RESET}"
                    echo -e "  ${COLOR_INFO}Guardando cambios temporalmente (git stash)...${COLOR_RESET}"
                    git stash push -m "auto-stash: crear commit rama va a UAT" 2>/dev/null
                    if git checkout -b "$nombre_rama" origin/uat 2>/dev/null; then
                        echo -e "  ${COLOR_SUCCESS}✓ Rama creada y activa: ${nombre_rama}${COLOR_RESET}"
                        echo -e "  ${COLOR_MUTED}  (cambios anteriores guardados en stash)${COLOR_RESET}"
                    else
                        echo -e "  ${COLOR_ERROR}Error al crear la rama${COLOR_RESET}"
                        git stash pop 2>/dev/null
                        return 1
                    fi
                else
                    echo -e "  ${COLOR_ERROR}Error: ${git_err}${COLOR_RESET}"
                    return 1
                fi
            fi
        ;;
        2)
            echo ""
            echo -e -n "  ${COLOR_TEXT}Nombre de la rama existente: ${COLOR_RESET}"
            read nombre_rama

            if [ -z "$nombre_rama" ]; then
                echo -e "  ${COLOR_WARNING}No se ingresó nombre de rama${COLOR_RESET}"
                return 1
            fi

            local checkout_cmd=""
            if git show-ref --verify --quiet "refs/heads/$nombre_rama" 2>/dev/null; then
                echo -e "  ${COLOR_INFO}Cambiando a rama ${COLOR_ACCENT}${nombre_rama}${COLOR_RESET}..."
                checkout_cmd="git checkout $nombre_rama"
            else
                echo -e "  ${COLOR_INFO}Rama no encontrada localmente, buscando en remoto...${COLOR_RESET}"
                if git ls-remote --heads origin "$nombre_rama" 2>/dev/null | grep -q .; then
                    checkout_cmd="git checkout -b $nombre_rama origin/$nombre_rama"
                else
                    echo -e "  ${COLOR_ERROR}Rama '${nombre_rama}' no existe local ni remotamente${COLOR_RESET}"
                    return 1
                fi
            fi

            local git_err
            git_err=$(eval "$checkout_cmd" 2>&1)
            if [ $? -eq 0 ]; then
                echo -e "  ${COLOR_SUCCESS}✓ Rama activa: ${nombre_rama}${COLOR_RESET}"
            else
                if echo "$git_err" | grep -qi "overwritten\|conflict\|uncommitted\|local changes"; then
                    echo -e "  ${COLOR_WARNING}Hay cambios locales que impiden el checkout.${COLOR_RESET}"
                    echo -e "  ${COLOR_INFO}Guardando cambios temporalmente (git stash)...${COLOR_RESET}"
                    git stash push -m "auto-stash: crear commit rama va a UAT" 2>/dev/null
                    if eval "$checkout_cmd" 2>/dev/null; then
                        echo -e "  ${COLOR_SUCCESS}✓ Rama activa: ${nombre_rama}${COLOR_RESET}"
                        echo -e "  ${COLOR_MUTED}  (cambios anteriores guardados en stash)${COLOR_RESET}"
                    else
                        echo -e "  ${COLOR_ERROR}Error al cambiar de rama${COLOR_RESET}"
                        git stash pop 2>/dev/null
                        return 1
                    fi
                else
                    echo -e "  ${COLOR_ERROR}Error: ${git_err}${COLOR_RESET}"
                    return 1
                fi
            fi

            # Preguntar si desea actualizar con lo último de UAT
            echo ""
            echo -e "  ${COLOR_INFO}¿Deseas actualizar esta rama con lo último de UAT?${COLOR_RESET}"
            echo -e -n "  ${COLOR_PRIMARY}→${COLOR_RESET} ${COLOR_TEXT}(S/N): ${COLOR_RESET}"
            read actualizar_uat

            if [[ "$actualizar_uat" =~ ^[Ss]$ ]]; then
                echo -e "  ${COLOR_INFO}Actualizando con origin/uat...${COLOR_RESET}"
                if git merge origin/uat --no-edit 2>/dev/null; then
                    echo -e "  ${COLOR_SUCCESS}✓ Rama actualizada con UAT${COLOR_RESET}"
                else
                    echo -e "  ${COLOR_ERROR}Conflictos al actualizar con UAT. Resuelve manualmente.${COLOR_RESET}"
                    git merge --abort 2>/dev/null
                    return 1
                fi
            fi
        ;;
        *)
            echo -e "  ${COLOR_WARNING}Opción inválida${COLOR_RESET}"
            return 1
        ;;
    esac

    # ── Fase 2: Cherry-pick del PR ──
    echo ""
    echo -e "  ${DIM}───────────────────────────────────${COLOR_RESET}"
    echo ""
    echo -e -n "  ${COLOR_TEXT}Ingrese el ID del Pull Request: ${COLOR_RESET}"
    read pr_id_input

    if [ -z "$pr_id_input" ]; then
        echo -e "  ${COLOR_WARNING}No se ingresó PR ID${COLOR_RESET}"
        return 1
    fi

    echo ""
    echo -e "  ${COLOR_INFO}Obteniendo información del PR #${pr_id_input}...${COLOR_RESET}"

    local pr_info
    pr_info=$(az repos pr show --id "$pr_id_input" --query "{title: title, status: status, mergeCommitId: lastMergeCommit.commitId, sourceBranch: sourceRefName, targetBranch: targetRefName}" -o json 2>/dev/null)

    if [ $? -ne 0 ] || [ -z "$pr_info" ]; then
        echo -e "  ${COLOR_ERROR}Error al obtener info del PR. Verifica el ID y tu autenticación en Azure.${COLOR_RESET}"
        return 1
    fi

    local pr_title
    pr_title=$(echo "$pr_info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('title',''))" 2>/dev/null)
    local pr_status
    pr_status=$(echo "$pr_info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status',''))" 2>/dev/null)
    local merge_commit
    merge_commit=$(echo "$pr_info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('mergeCommitId',''))" 2>/dev/null)
    local source_branch
    source_branch=$(echo "$pr_info" | python3 -c "import sys,json; print(json.load(sys.stdin).get('sourceBranch','').replace('refs/heads/',''))" 2>/dev/null)

    echo -e "  ${COLOR_MUTED}─────────────────────────────────────────${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Título:  ${COLOR_ACCENT}${pr_title}${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Estado:  ${COLOR_ACCENT}${pr_status}${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Rama:    ${COLOR_ACCENT}${source_branch}${COLOR_RESET}"
    echo -e "  ${COLOR_TEXT}Commit:  ${COLOR_ACCENT}${merge_commit:0:12}${COLOR_RESET}"
    echo -e "  ${COLOR_MUTED}─────────────────────────────────────────${COLOR_RESET}"

    if [ -z "$merge_commit" ] || [ "$merge_commit" = "None" ]; then
        echo -e "  ${COLOR_ERROR}El PR no tiene merge commit. ¿Está completado?${COLOR_RESET}"
        return 1
    fi

    # Fetch para asegurar que el commit esté disponible
    echo ""
    echo -e "  ${COLOR_INFO}Descargando commits...${COLOR_RESET}"
    git fetch origin 2>/dev/null

    # Cherry-pick con --no-commit para poder agregar manifests
    echo -e "  ${COLOR_INFO}Aplicando cherry-pick del commit ${merge_commit:0:12}...${COLOR_RESET}"

    if git cherry-pick --no-commit "$merge_commit" 2>/dev/null; then
        echo -e "  ${COLOR_SUCCESS}✓ Cherry-pick aplicado exitosamente${COLOR_RESET}"
    else
        local conflictos
        conflictos=$(git diff --name-only --diff-filter=U 2>/dev/null)
        if [ -n "$conflictos" ]; then
            echo ""
            echo -e "  ${COLOR_ERROR}Conflictos detectados en:${COLOR_RESET}"
            echo "$conflictos" | while IFS= read -r archivo; do
                echo -e "    ${COLOR_WARNING}• ${archivo}${COLOR_RESET}"
            done
            echo ""
            echo -e "  ${COLOR_ERROR}Abortando cherry-pick. Resuelve los conflictos manualmente.${COLOR_RESET}"
            git cherry-pick --abort 2>/dev/null
            return 1
        else
            echo -e "  ${COLOR_ERROR}Error al aplicar cherry-pick${COLOR_RESET}"
            git cherry-pick --abort 2>/dev/null
            return 1
        fi
    fi

    # ── Fase 3: Actualizar manifests automáticamente ──
    echo ""
    echo -e "  ${DIM}───────────────────────────────────${COLOR_RESET}"
    echo -e "  ${COLOR_INFO}${BOLD}Actualizando manifests...${COLOR_RESET}"
    echo ""

    local core_nuevos=0
    local vlocity_nuevos=0

    # --- CORE: package.xml ---
    local archivos_core
    archivos_core=$(git diff --cached --name-only 2>/dev/null | grep "^force-app/" || true)

    if [ -n "$archivos_core" ]; then
        echo -e "  ${COLOR_INFO}Generando delta CORE...${COLOR_RESET}"

        local delta_dir="/tmp/sgd-delta-$$"
        rm -rf "$delta_dir"
        mkdir -p "$delta_dir"

        cd "$PROJECT_ROOT" || return 1

        if sf sgd source delta --to "$merge_commit" --from HEAD --output-dir "$delta_dir" 2>/dev/null; then
            if [ -f "$delta_dir/package/package.xml" ]; then
                echo -e "  ${COLOR_INFO}Merging CORE en ${MANIFEST_DIR}/${XML_COMPONENTES}...${COLOR_RESET}"

                local merge_output
                merge_output=$(python3 scripts/pr_commit_report.py --merge-manifest ${MANIFEST_DIR}/${XML_COMPONENTES} "$delta_dir/package/package.xml" 2>/dev/null)

                core_nuevos=$(echo "$merge_output" | grep "MEMBERS_NUEVOS=" | cut -d= -f2)
                local total_core
                total_core=$(echo "$merge_output" | grep "TOTAL_MEMBERS=" | cut -d= -f2)

                echo -e "  ${COLOR_SUCCESS}✓ CORE: ${core_nuevos:-0} componentes nuevos (total: ${total_core:-0})${COLOR_RESET}"
                git add ${MANIFEST_DIR}/${XML_COMPONENTES} 2>/dev/null
            else
                echo -e "  ${COLOR_MUTED}  No se generó delta CORE${COLOR_RESET}"
            fi
        else
            echo -e "  ${COLOR_WARNING}  sgd no pudo generar delta, usando método alternativo...${COLOR_RESET}"

            local temp_pkg="/tmp/cherry-pick-delta-$$.xml"
            echo '<?xml version="1.0" encoding="UTF-8"?>' > "$temp_pkg"
            echo '<Package xmlns="http://soap.sforce.com/2006/04/metadata">' >> "$temp_pkg"

            declare -A tipo_members
            while IFS= read -r archivo; do
                local rel_path="${archivo#force-app/main/default/}"
                local tipo_dir="${rel_path%%/*}"

                case "$tipo_dir" in
                    classes) tipo_members["ApexClass"]+="$(basename "$archivo" .cls | sed 's/\.cls-meta//')|" ;;
                    triggers) tipo_members["ApexTrigger"]+="$(basename "$archivo" .trigger | sed 's/\.trigger-meta//')|" ;;
                    lwc) local comp_name=$(echo "$rel_path" | cut -d'/' -f2); tipo_members["LightningComponentBundle"]+="${comp_name}|" ;;
                    aura) local comp_name=$(echo "$rel_path" | cut -d'/' -f2); tipo_members["AuraDefinitionBundle"]+="${comp_name}|" ;;
                    flows) tipo_members["Flow"]+="$(basename "$archivo" .flow-meta.xml)|" ;;
                    flexipages) tipo_members["FlexiPage"]+="$(basename "$archivo" .flexipage-meta.xml)|" ;;
                    objects)
                        local obj_name=$(echo "$rel_path" | cut -d'/' -f2)
                        local sub_dir=$(echo "$rel_path" | cut -d'/' -f3)
                        case "$sub_dir" in
                            fields) tipo_members["CustomField"]+="${obj_name}.$(basename "$archivo" .field-meta.xml)|" ;;
                            validationRules) tipo_members["ValidationRule"]+="${obj_name}.$(basename "$archivo" .validationRule-meta.xml)|" ;;
                            recordTypes) tipo_members["RecordType"]+="${obj_name}.$(basename "$archivo" .recordType-meta.xml)|" ;;
                            listViews) tipo_members["ListView"]+="${obj_name}.$(basename "$archivo" .listView-meta.xml)|" ;;
                            *) tipo_members["CustomObject"]+="${obj_name}|" ;;
                        esac
                    ;;
                    permissionsets) tipo_members["PermissionSet"]+="$(basename "$archivo" .permissionset-meta.xml)|" ;;
                    layouts) tipo_members["Layout"]+="$(basename "$archivo" .layout-meta.xml)|" ;;
                    customMetadata) tipo_members["CustomMetadata"]+="$(basename "$archivo" .md-meta.xml)|" ;;
                    labels) tipo_members["CustomLabel"]+="CustomLabels|" ;;
                    staticresources) tipo_members["StaticResource"]+="$(basename "$archivo" | sed 's/\..*$//')|" ;;
                    tabs) tipo_members["CustomTab"]+="$(basename "$archivo" .tab-meta.xml)|" ;;
                    profiles) tipo_members["Profile"]+="$(basename "$archivo" .profile-meta.xml)|" ;;
                    remoteSiteSettings) tipo_members["RemoteSiteSetting"]+="$(basename "$archivo" .remoteSite-meta.xml)|" ;;
                    namedCredentials) tipo_members["NamedCredential"]+="$(basename "$archivo" .namedCredential-meta.xml)|" ;;
                    queues) tipo_members["Queue"]+="$(basename "$archivo" .queue-meta.xml)|" ;;
                esac
            done <<< "$archivos_core"

            for tipo in "${!tipo_members[@]}"; do
                echo "    <types>" >> "$temp_pkg"
                echo "${tipo_members[$tipo]}" | tr '|' '\n' | sort -u | while IFS= read -r member; do
                    [ -n "$member" ] && echo "        <members>${member}</members>" >> "$temp_pkg"
                done
                echo "        <name>${tipo}</name>" >> "$temp_pkg"
                echo "    </types>" >> "$temp_pkg"
            done

            echo '    <version>65.0</version>' >> "$temp_pkg"
            echo '</Package>' >> "$temp_pkg"

            local merge_output
            merge_output=$(python3 scripts/pr_commit_report.py --merge-manifest ${MANIFEST_DIR}/${XML_COMPONENTES} "$temp_pkg" 2>/dev/null)
            core_nuevos=$(echo "$merge_output" | grep "MEMBERS_NUEVOS=" | cut -d= -f2)
            local total_core
            total_core=$(echo "$merge_output" | grep "TOTAL_MEMBERS=" | cut -d= -f2)

            echo -e "  ${COLOR_SUCCESS}✓ CORE: ${core_nuevos:-0} componentes nuevos (total: ${total_core:-0})${COLOR_RESET}"
            git add ${MANIFEST_DIR}/${XML_COMPONENTES} 2>/dev/null

            rm -f "$temp_pkg"
        fi

        rm -rf "$delta_dir"
    else
        echo -e "  ${COLOR_MUTED}  Sin cambios CORE en este PR${COLOR_RESET}"
    fi

    # --- VLOCITY: package.yaml ---
    local archivos_vlocity
    archivos_vlocity=$(git diff --cached --name-only 2>/dev/null | grep "^vlocity/" || true)

    if [ -n "$archivos_vlocity" ]; then
        echo ""
        echo -e "  ${COLOR_INFO}Actualizando manifest Vlocity...${COLOR_RESET}"

        local nuevos_componentes=()
        local componentes_vistos=()

        while IFS= read -r archivo; do
            local vlocity_path="${archivo#vlocity/}"
            local vtype="${vlocity_path%%/*}"
            local rest="${vlocity_path#*/}"
            local vname="${rest%%/*}"

            if [ -n "$vtype" ] && [ -n "$vname" ]; then
                local comp_key="${vtype}/${vname}"
                local ya_visto=false
                for v in "${componentes_vistos[@]}"; do
                    [ "$v" = "$comp_key" ] && ya_visto=true && break
                done
                if [ "$ya_visto" = false ]; then
                    componentes_vistos+=("$comp_key")
                    nuevos_componentes+=("$comp_key")
                fi
            fi
        done <<< "$archivos_vlocity"

        local yaml_path="${PROJECT_ROOT}/${MANIFEST_DIR}/${YAML_COMPONENTES}"
        local existentes=()
        if [ -f "$yaml_path" ]; then
            while IFS= read -r line; do
                local stripped=$(echo "$line" | sed 's/^[[:space:]]*//')
                if [[ "$stripped" == -\ * ]]; then
                    local comp="${stripped#- }"
                    comp=$(echo "$comp" | sed 's/#.*//' | sed 's/[[:space:]]*$//')
                    if [[ "$comp" == */* ]] && [ "$comp" != "xxx" ]; then
                        existentes+=("$comp")
                    fi
                fi
            done < "$yaml_path"
        fi

        local realmente_nuevos=()
        for nuevo in "${nuevos_componentes[@]}"; do
            local es_existente=false
            for existente in "${existentes[@]}"; do
                [ "$existente" = "$nuevo" ] && es_existente=true && break
            done
            if [ "$es_existente" = false ]; then
                realmente_nuevos+=("$nuevo")
            fi
        done

        local todos_componentes=()
        for c in "${existentes[@]}"; do
            todos_componentes+=("$c")
        done
        for c in "${realmente_nuevos[@]}"; do
            todos_componentes+=("$c")
        done

        local sorted_components
        sorted_components=$(printf '%s\n' "${todos_componentes[@]}" | sort -u)

        local vlocity_entries=""
        while IFS= read -r comp; do
            [ -n "$comp" ] && vlocity_entries+="    - ${comp}\n"
        done <<< "$sorted_components"

        printf "projectPath: .\nexpansionPath: ./vlocity/\nmanifest:\n${vlocity_entries}\ndelete: true\nactivate: true\ncompileOnBuild: true\nmaxDepth: 0\ncontinueAfterError: true\nuseAllRelationships: false\nsupportHeadersOnly: true\nsupportForceDeploy: true\nverbose: false\ndeltaGeneration: false\n" > "$yaml_path"

        vlocity_nuevos=${#realmente_nuevos[@]}
        local total_vlocity
        total_vlocity=$(echo "$sorted_components" | grep -c ".")

        echo -e "  ${COLOR_SUCCESS}✓ VLOCITY: ${vlocity_nuevos} componentes nuevos (total: ${total_vlocity})${COLOR_RESET}"
        git add ${MANIFEST_DIR}/${YAML_COMPONENTES} 2>/dev/null
    else
        echo -e "  ${COLOR_MUTED}  Sin cambios Vlocity en este PR${COLOR_RESET}"
    fi

    # ── Fase 4: Commit y resumen ──
    echo ""
    echo -e "  ${DIM}───────────────────────────────────${COLOR_RESET}"
    echo ""

    local commit_msg="Migrate: PR #${pr_id_input} - ${pr_title}"

    echo -e "  ${COLOR_INFO}Creando commit...${COLOR_RESET}"
    echo -e "  ${COLOR_MUTED}${commit_msg}${COLOR_RESET}"

    if git commit -m "$commit_msg" 2>/dev/null; then
        echo ""
        echo -e "  ${COLOR_SUCCESS}${BOLD}╭───────────────────────────────────────╮${COLOR_RESET}"
        echo -e "  ${COLOR_SUCCESS}${BOLD}│     Commit creado exitosamente        │${COLOR_RESET}"
        echo -e "  ${COLOR_SUCCESS}${BOLD}╰───────────────────────────────────────╯${COLOR_RESET}"
        echo ""
        echo -e "  ${COLOR_TEXT}PR:       ${COLOR_ACCENT}#${pr_id_input} - ${pr_title}${COLOR_RESET}"
        echo -e "  ${COLOR_TEXT}Rama:     ${COLOR_ACCENT}$(git branch --show-current)${COLOR_RESET}"
        echo -e "  ${COLOR_TEXT}CORE:     ${COLOR_ACCENT}${core_nuevos:-0} componentes nuevos${COLOR_RESET}"
        echo -e "  ${COLOR_TEXT}Vlocity:  ${COLOR_ACCENT}${vlocity_nuevos:-0} componentes nuevos${COLOR_RESET}"
        echo ""

        echo -e -n "  ${COLOR_TEXT}¿Deseas hacer push de la rama? (S/N): ${COLOR_RESET}"
        read hacer_push
        if [[ "$hacer_push" =~ ^[Ss]$ ]]; then
            local rama_actual
            rama_actual=$(git branch --show-current)
            echo -e "  ${COLOR_INFO}Ejecutando: git push origin ${rama_actual}${COLOR_RESET}"
            if git push origin "$rama_actual" 2>/dev/null; then
                echo -e "  ${COLOR_SUCCESS}✓ Push realizado exitosamente${COLOR_RESET}"
            else
                echo -e "  ${COLOR_WARNING}Error al hacer push. Intenta manualmente.${COLOR_RESET}"
            fi
        fi
    else
        echo -e "  ${COLOR_ERROR}Error al crear el commit${COLOR_RESET}"
        return 1
    fi
}

