        echo -e "${COLOR_WARNING}  El PR #${pr_id} ya fue completado anteriormente.${COLOR_RESET}"
        echo -e "${COLOR_MUTED}  No es necesario aprobarlo/completarlo nuevamente.${COLOR_RESET}"
        return 0
