    echo -e "${COLOR_PRIMARY}→${COLOR_RESET} ${COLOR_TEXT}Número de Sprint (ej: SP22):${COLOR_RESET} "
    read sprint_numero
    if [ -z "$sprint_numero" ]; then
        echo -e "${COLOR_WARNING}Sprint no ingresado. Tracking cancelado.${COLOR_RESET}"
        return 1
    fi

    # HU
    echo -e "${COLOR_PRIMARY}→${COLOR_RESET} ${COLOR_TEXT}Número de HU (ej: 31888):${COLOR_RESET} "
    read hu_numero
    if [ -z "$hu_numero" ]; then
        echo -e "${COLOR_WARNING}HU no ingresada. Tracking cancelado.${COLOR_RESET}"
        return 1
    fi

    # PR ID
    echo -e "${COLOR_PRIMARY}→${COLOR_RESET} ${COLOR_TEXT}ID del Pull Request (ej: 10750):${COLOR_RESET} "
    read pr_id
    if [ -z "$pr_id" ]; then
        echo -e "${COLOR_WARNING}PR ID no ingresado. Tracking cancelado.${COLOR_RESET}"
        return 1
    fi

    # Guardar PR ID en variable global para uso posterior (Azure DevOps)
    ULTIMO_PR_ID="$pr_id"

    local url_pr="${URL_BASE_PR}${pr_id}"

    # Mostrar resumen antes de procesar
    echo -e "\n${COLOR_INFO}╔═══════════════════════════════════════════════════════════╗"
    echo -e "║                    Resumen de Tracking                    ║"
    echo -e "╚═══════════════════════════════════════════════════════════╝${COLOR_RESET}"
    echo -e "${COLOR_TEXT}  Proyecto:        ${COLOR_ACCENT}SURA Banca${COLOR_RESET}"
    echo -e "${COLOR_TEXT}  Tipo Componente: ${COLOR_ACCENT}${tipo_componente}${COLOR_RESET}"
    echo -e "${COLOR_TEXT}  Sprint:          ${COLOR_ACCENT}${sprint_numero}${COLOR_RESET}"
    echo -e "${COLOR_TEXT}  HU:              ${COLOR_ACCENT}${hu_numero}${COLOR_RESET}"
    echo -e "${COLOR_TEXT}  URL PR:          ${COLOR_ACCENT}${url_pr}${COLOR_RESET}"

    # Parsear el XML y crear registros
    echo -e "\n${COLOR_INFO}Procesando componentes del manifest...${COLOR_RESET}\n"

    # Obtener la ruta base del proyecto
    local SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local PROJECT_ROOT="$(git -C "$(pwd)" rev-parse --show-toplevel 2>/dev/null || pwd)"
    local full_manifest_path="${PROJECT_ROOT}/${manifest_file}"

    # Verificar que el archivo existe
    if [ ! -f "$full_manifest_path" ]; then
        echo -e "${COLOR_ERROR}Error: No se encontró el archivo ${full_manifest_path}${COLOR_RESET}"
        return 1
    fi

    # Parsear el XML y extraer componentes
    local componentes_creados=0
    local componentes_fallidos=0

    # Guardar componentes en un archivo temporal para evitar subshell
    local temp_file=$(mktemp)

    # Extraer todos los bloques types con sus members y name usando awk
    awk '
    /<types>/ { in_block=1; members=""; name="" }
    /<members>/ && in_block {
        gsub(/.*<members>/, "");
        gsub(/<\/members>.*/, "");
        gsub(/^[ \t]+|[ \t]+$/, "");
        if (members != "") members = members "|";
        members = members $0;
    }
    /<name>/ && in_block {
        gsub(/.*<name>/, "");
        gsub(/<\/name>.*/, "");
        gsub(/^[ \t]+|[ \t]+$/, "");
        name = $0;
    }
    /<\/types>/ && in_block {
        if (name != "" && members != "") {
            n = split(members, arr, "|");
            for (i=1; i<=n; i++) {
                print name ":" arr[i];
            }
        }
        in_block=0;
    }
    ' "$full_manifest_path" > "$temp_file"

    # Contar total de componentes
    local total_componentes=$(wc -l < "$temp_file" | tr -d ' ')
    local contador_actual=0

    while IFS=: read -r metadata_type member; do
        echo -e "${COLOR_MUTED}  Creando: ${metadata_type} - ${member}${COLOR_RESET}"

        # Crear el registro en Salesforce
        sf data create record \
            --sobject TrackingComponent__c \
            --values "Proyecto__c='SURA Banca' TipoComponente__c='${tipo_componente}' TipoMetadato__c='${metadata_type}' Name='registro-en-ComponentName__c' ComponentName__c='${member}' Sprint__c='${sprint_numero}' HU__c='${hu_numero}' URL_PR__c='${url_pr}'" \
            --target-org ${ORG_TRACKING} --json > /dev/null 2>&1

        local cmd_result=$?
        ((contador_actual++))
        if [ $cmd_result -eq 0 ]; then
            echo -e "${COLOR_SUCCESS}    ✓ Creado exitosamente ${contador_actual}/${total_componentes}${COLOR_RESET}"
            ((componentes_creados++))
        else
            echo -e "${COLOR_ERROR}    ✗ Error al crear ${contador_actual}/${total_componentes}${COLOR_RESET}"
            ((componentes_fallidos++))
        fi
    done < "$temp_file"

    # Eliminar archivo temporal
    rm -f "$temp_file"

    # Mostrar resumen final
    echo -e "\n${COLOR_SUCCESS}╔═══════════════════════════════════════════════════════════╗"
    echo -e "║                    Tracking Completado                    ║"
    echo -e "╚═══════════════════════════════════════════════════════════╝${COLOR_RESET}"
    echo -e "${COLOR_SUCCESS}  Componentes creados: ${componentes_creados}${COLOR_RESET}"
    if [ $componentes_fallidos -gt 0 ]; then
        echo -e "${COLOR_ERROR}  Componentes fallidos: ${componentes_fallidos}${COLOR_RESET}"
    fi

    return 0
}

