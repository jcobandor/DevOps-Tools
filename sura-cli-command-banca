# Función para gestionar el monitor automático de PRs
function gestionar_monitor_prs() {
    local SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local MONITOR_SCRIPT="${SCRIPT_DIR}/jarvis/auto_pr_monitor.py"
    local CONFIG_FILE="${SCRIPT_DIR}/jarvis/.pr_monitor_config.json"
    local CRON_CMD="*/30 7-23 * * 1-6 cd ${SCRIPT_DIR} && /usr/bin/python3 ${MONITOR_SCRIPT} --check >> ${SCRIPT_DIR}/jarvis/.pr_monitor.log 2>&1"

    echo ""
    echo -e "  ${TITLE}"
    echo "  ╭───────────────────────────────────────────────────╮"
    echo "  │       Monitor Automático de PRs Completados       │"
    echo "  ╰───────────────────────────────────────────────────╯"
    echo -e "  ${COLOR_RESET}"
    echo -e "  ${MUTED}Notifica via Teams y macOS cuando se completa un PR hacia UAT o Main${COLOR_RESET}"

    if ! command -v python3 &> /dev/null; then
        echo -e "  ${COLOR_ERROR}Error: Python3 no está instalado${COLOR_RESET}"
        return 1
    fi

    if [ ! -f "$MONITOR_SCRIPT" ]; then
        echo -e "  ${COLOR_ERROR}Error: No se encontró ${MONITOR_SCRIPT}${COLOR_RESET}"
        return 1
    fi

    # Detectar estado actual
    local cron_activo=false
    if crontab -l 2>/dev/null | grep -q "auto_pr_monitor"; then
        cron_activo=true
    fi

    local webhook_configurado=false
    if [ -f "$CONFIG_FILE" ]; then
        local has_wh=$(python3 -c "import json; c=json.load(open('$CONFIG_FILE')); print('yes' if c.get('teams_webhook_url') else 'no')" 2>/dev/null)
        if [ "$has_wh" = "yes" ]; then
            webhook_configurado=true
        fi
    fi

    while true; do
        echo ""
        if [ "$cron_activo" = true ]; then
            echo -e "  ${COLOR_SUCCESS}Estado: ACTIVO (cada 30 min, Lun-Sáb 7am-11:30pm)${COLOR_RESET}"
        else
            echo -e "  ${COLOR_WARNING}Estado: INACTIVO${COLOR_RESET}"
        fi

        if [ "$webhook_configurado" = true ]; then
            echo -e "  ${MUTED}Teams: Webhook configurado${COLOR_RESET}"
        else
            echo -e "  ${MUTED}Teams: Webhook no configurado (solo notificación macOS)${COLOR_RESET}"
        fi
        echo ""

        if [ "$cron_activo" = true ]; then
            echo -e "  ${OPTION}1.${COLOR_RESET}  Desactivar monitor"
        else
            echo -e "  ${OPTION}1.${COLOR_RESET}  Activar monitor"
        fi
        echo -e "  ${OPTION}2.${COLOR_RESET}  Configurar Teams Webhook"
        echo -e "  ${OPTION}3.${COLOR_RESET}  Ejecutar verificación ahora"
        echo -e "  ${OPTION}4.${COLOR_RESET}  Ver log de actividad"
        echo -e "  ${OPTION}5.${COLOR_RESET}  Limpiar historial de PRs notificados"
        echo -e "  ${OPTION}6.${COLOR_RESET}  Ver PRs en base de datos"
        echo -e "  ${OPTION}7.${COLOR_RESET}  Ver historial de ejecuciones del cron"
        echo ""
        echo -e "  ${COLOR_SUCCESS}0.  Volver${COLOR_RESET}"
        echo ""
        echo -e "  ${DIM}───────────────────────────────────────${COLOR_RESET}"
        echo -e -n "  ${COLOR_PRIMARY}→${COLOR_RESET} "
        read opcion_monitor

        case $opcion_monitor in
            0)
                return 0
            ;;
            1)
                if [ "$cron_activo" = true ]; then
                    crontab -l 2>/dev/null | grep -v "auto_pr_monitor" | crontab -
                    if [ -f "$CONFIG_FILE" ]; then
                        python3 -c "
import json
c = json.load(open('$CONFIG_FILE'))
c['active'] = False
json.dump(c, open('$CONFIG_FILE', 'w'), indent=2)
"
                    fi
                    cron_activo=false
                    echo ""
                    echo -e "  ${COLOR_SUCCESS}Monitor desactivado. Cron eliminado.${COLOR_RESET}"
                else
                    # Activar cron
                    (echo 'PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin'; echo ''; crontab -l 2>/dev/null | grep -v "auto_pr_monitor" | grep -v "^PATH="; echo "$CRON_CMD") | crontab -

                    # Crear/actualizar config
                    if [ ! -f "$CONFIG_FILE" ]; then
                        python3 -c "
import json
json.dump({'teams_webhook_url':'','target_branches':['uat','main'],'active':True}, open('$CONFIG_FILE','w'), indent=2)
"
                    else
                        python3 -c "
import json
c = json.load(open('$CONFIG_FILE'))
c['active'] = True
json.dump(c, open('$CONFIG_FILE', 'w'), indent=2)
"
                    fi
                    cron_activo=true
                    echo ""
                    echo -e "  ${COLOR_SUCCESS}Monitor activado. Se ejecutará cada 30 min (Lun-Vie 8am-6pm).${COLOR_RESET}"
                    if [ "$webhook_configurado" = false ]; then
                        echo -e "  ${MUTED}Nota: Sin webhook, recibirás notificación macOS + reporte en navegador.${COLOR_RESET}"
                    fi
                fi
            ;;
            2)
                echo ""
                echo -e "  ${COLOR_TEXT}Configuración de Microsoft Teams Webhook${COLOR_RESET}"
                echo ""
                echo -e "  ${MUTED}Para crear un webhook en Teams:${COLOR_RESET}"
                echo -e "  ${MUTED}1. Abre el canal de Teams donde quieres las notificaciones${COLOR_RESET}"
                echo -e "  ${MUTED}2. Clic en ··· → Conectores (o Workflows)${COLOR_RESET}"
                echo -e "  ${MUTED}3. Busca 'Incoming Webhook' → Configurar${COLOR_RESET}"
                echo -e "  ${MUTED}4. Dale un nombre (ej: 'Monitor PRs') → Crear${COLOR_RESET}"
                echo -e "  ${MUTED}5. Copia la URL del webhook${COLOR_RESET}"
                echo ""
                echo -e -n "  ${COLOR_TEXT}Pegue la URL del webhook: ${COLOR_RESET}"
                read webhook_url

                if [ -z "$webhook_url" ]; then
                    echo -e "  ${COLOR_WARNING}No se ingresó URL${COLOR_RESET}"
                    continue
                fi

                # Guardar config
                python3 -c "
import json
config = {'teams_webhook_url': '$webhook_url', 'target_branches': ['uat', 'main'], 'active': $( [ '$cron_activo' = true ] && echo 'True' || echo 'False' )}
existing = {}
try:
    existing = json.load(open('$CONFIG_FILE'))
except: pass
existing.update(config)
json.dump(existing, open('$CONFIG_FILE', 'w'), indent=2)
"
                webhook_configurado=true

                # Test
                echo -e -n "  ${COLOR_TEXT}¿Enviar mensaje de prueba a Teams? (S/N): ${COLOR_RESET}"
                read test_teams
                if [[ "$test_teams" =~ ^[Ss]$ ]]; then
                    echo -e "  ${COLOR_INFO}Enviando mensaje de prueba...${COLOR_RESET}"
                    python3 -c "
import urllib.request, urllib.error, json
url = '$webhook_url'
# Intentar Adaptive Card primero
card = {'type':'message','attachments':[{'contentType':'application/vnd.microsoft.card.adaptive','contentUrl':None,'content':{'type':'AdaptiveCard','version':'1.4','body':[{'type':'TextBlock','text':'Monitor de PRs configurado correctamente','weight':'Bolder','size':'Medium'},{'type':'TextBlock','text':'Recibirás notificaciones cuando se completen PRs hacia UAT o Main.','wrap':True}]}}]}
try:
    data = json.dumps(card).encode('utf-8')
    req = urllib.request.Request(url, data=data, headers={'Content-Type':'application/json'})
    resp = urllib.request.urlopen(req, timeout=10)
    print('OK')
except urllib.error.HTTPError:
    # Fallback: formato simple para Workflows
    simple = {'title':'Monitor de PRs','body':'Configurado correctamente. Recibirás notificaciones cuando se completen PRs hacia UAT o Main.'}
    try:
        data2 = json.dumps(simple).encode('utf-8')
        req2 = urllib.request.Request(url, data=data2, headers={'Content-Type':'application/json'})
        resp2 = urllib.request.urlopen(req2, timeout=10)
        print('OK')
    except Exception as e:
        print(f'ERROR:{e}')
except Exception as e:
    print(f'ERROR:{e}')
" 2>/dev/null | while read line; do
                        if [ "$line" = "OK" ]; then
                            echo -e "  ${COLOR_SUCCESS}Mensaje enviado a Teams correctamente${COLOR_RESET}"
                        else
                            echo -e "  ${COLOR_ERROR}${line}${COLOR_RESET}"
                            echo -e "  ${MUTED}Verifique la URL del webhook e intente de nuevo${COLOR_RESET}"
                        fi
                    done
                fi
                echo -e "  ${COLOR_SUCCESS}Webhook guardado${COLOR_RESET}"
            ;;
            3)
                echo ""
                echo -e "  ${COLOR_INFO}Ejecutando verificación manual...${COLOR_RESET}"
                echo ""
                cd "$SCRIPT_DIR"
                python3 "$MONITOR_SCRIPT" --check
                echo ""
                echo -e "  ${COLOR_SUCCESS}Verificación completada${COLOR_RESET}"
            ;;
            4)
                local LOG_FILE="${SCRIPT_DIR}/jarvis/.pr_monitor.log"
                echo ""
                if [ -f "$LOG_FILE" ]; then
                    echo -e "  ${COLOR_TEXT}Últimas 20 líneas del log:${COLOR_RESET}"
                    echo -e "  ${MUTED}─────────────────────────────────────────${COLOR_RESET}"
                    tail -20 "$LOG_FILE" | while IFS= read -r line; do
                        echo -e "  ${MUTED}${line}${COLOR_RESET}"
                    done
                    echo -e "  ${MUTED}─────────────────────────────────────────${COLOR_RESET}"
                else
                    echo -e "  ${MUTED}No hay log aún. Ejecute una verificación primero.${COLOR_RESET}"
                fi
            ;;
            5)
                echo ""
                cd "$SCRIPT_DIR"
                python3 "$MONITOR_SCRIPT" --clear
                echo -e "  ${COLOR_SUCCESS}Historial limpiado${COLOR_RESET}"
            ;;
            6)
                echo ""
                cd "$SCRIPT_DIR"
                python3 "$MONITOR_SCRIPT" --db-status
            ;;
            7)
                echo ""
                cd "$SCRIPT_DIR"
                python3 "$MONITOR_SCRIPT" --cron-log
            ;;
            *)
                echo -e "  ${COLOR_WARNING}Opción inválida${COLOR_RESET}"
            ;;
        esac
    done
}

