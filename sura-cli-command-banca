        echo -e "${COLOR_MUTED}Instale con: brew install azure-cli && az extension add --name azure-devops${COLOR_RESET}"
        return 1
    fi

    # Verificar estado del PR antes de continuar
    local pr_status=$(az repos pr show --id "$pr_id" --query "status" -o tsv 2>/dev/null)
